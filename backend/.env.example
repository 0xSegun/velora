# Application
APP_NAME=Velora
APP_ENV=development
DEBUG=false

# PostgreSQL
POSTGRES_USER=inflation_app
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=inflation_prediction_db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://inflation_app:change-me-strong-password@127.0.0.1:5432/inflation_prediction_db

# Security — generate with: openssl rand -hex 32
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE=7

# Redis (optional — sessions / caching)
REDIS_URL=redis://localhost:6379/0

# Email — auto picks resend > smtp > console (logs to backend/logs/)
EMAIL_MODE=auto
EMAIL_FROM=Velora <noreply@yourdomain.com>
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_USE_TLS=true

# Resend (alternative email provider)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Velora <onboarding@resend.dev>

# OAuth & External APIs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRED_API_KEY=
OPENAI_API_KEY=

# Frontend
FRONTEND_URL=https://your-frontend-domain.com

# Default admin — CHANGE IMMEDIATELY IN PRODUCTION
ADMIN_EMAIL=admin@inflationplatform.com
ADMIN_PASSWORD=Admin123!
ADMIN_FIRST_NAME=Platform
ADMIN_LAST_NAME=Admin
# Disable demo admin credentials endpoint in production
SHOW_DEFAULT_ADMIN_CREDENTIALS=false