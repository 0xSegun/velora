# =============================================
# Velora - AI Inflation Prediction Platform
# Environment Variables
# =============================================

# --- Database ---
DB_USER=velora
DB_PASSWORD=velora_secret
DB_NAME=velora
DATABASE_URL=postgresql+asyncpg://velora:velora_secret@localhost:5432/velora

# --- Security ---
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- NextAuth.js ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-this

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Resend (Email) ---
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@velora.com

# --- FRED API (Federal Reserve Economic Data) ---
FRED_API_KEY=your-fred-api-key

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","https://velora.vercel.app"]
